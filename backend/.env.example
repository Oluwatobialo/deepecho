# ========== Supabase (required for auth + database) ==========
# From Supabase Dashboard > Settings > API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=eyJ...your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key
# JWT Secret (same page, under "JWT Settings") - required to verify tokens
SUPABASE_JWT_SECRET=your-jwt-secret-string

# From Supabase Dashboard → Settings → Database → Connection string → URI
# Replace [YOUR-PASSWORD] with your project's database password
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.YOUR-PROJECT-REF.supabase.co:5432/postgres

# ========== Model (optional) ==========
# Path to MentalBERT model folder (default: ./models/mental-bert)
MODEL_PATH=./models/mental-bert

# Optional: Hugging Face token for gated/private models
# HF_TOKEN=hf_xxxxxxxxxxxx
# HF_MODEL_ID=your-username/your-model-name

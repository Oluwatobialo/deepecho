# Copy to .env and fill in your values. No real secrets in this file.

# Database (Supabase PostgreSQL or local)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Supabase — Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase — JWT Settings (verify tokens)
SUPABASE_JWT_SECRET=your-jwt-secret

# MentalBERT model path (optional; for /api/analyze)
MODEL_PATH=./models/mental-bert-base-uncased
